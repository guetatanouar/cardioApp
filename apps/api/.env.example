# Server Configuration
NODE_ENV=development
PORT=4000

# Database Configuration
# Format: postgresql://username:password@localhost:5432/database_name
# If your password contains special characters, URL-encode them
# Example: postgresql://postgres:P%40ssw0rd@localhost:5432/cardiomanager
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/cardiomanager
PG_ADMIN_DB=postgres

# Authentication
# Use a strong, random secret in production (at least 32 characters)
JWT_SECRET=your-super-secret-key-change-this-in-production-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS Configuration
# For multiple origins, separate with commas: http://localhost:3000,https://example.com
CORS_ORIGIN=http://localhost:3000

# File Uploads
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
