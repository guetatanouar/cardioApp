{
  "name": "cardiomanager-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend Express for CardioManager",
  "main": "index.ts",
  "scripts": {
    "dev": "node --import tsx --watch index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node --import tsx db/migrate.ts",
    "db:seed": "node --import tsx db/seed.ts"
  },
  "dependencies": {
    "@cardiomanager/web": "file:..",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.10.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/multer": "^1.4.7",
    "@types/node": "^18.15.11",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.6.6",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.4"
  }
}
